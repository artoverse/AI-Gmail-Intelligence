# Environment Variables — AI Gmail Intelligence Platform
# Copy this file to .env.local and fill in your values
# Do NOT commit .env.local to version control

# ── Supabase ──────────────────────────────────────────────────
# From Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Google OAuth (Gmail API) ───────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Ensure you have enabled the Gmail API in your Google Cloud project
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_key

# App URL — used for OAuth redirect URIs
# Add these redirect URIs in Google Cloud Console:
#   http://localhost:3000/api/gmail/connect/callback  (local development)
#   https://your-app.vercel.app/api/gmail/connect/callback  (production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google Gemini (Secondary AI Model) ────────────────────────
# From Google AI Studio → aistudio.google.com → Get API Key
# Used as a fallback/secondary AI model (required by assignment)
GEMINI_API_KEY=your_gemini_api_key_here

# ── NVIDIA NIM (Primary AI Model + Embeddings) ────────────────
# Sign up at build.nvidia.com → Get API Key (free tier available)
# Primary model: meta/llama-3.1-8b-instruct (chat, summarization, categorization)
# Embedding model: nvidia/nv-embedqa-e5-v5 (1024-dim vectors for semantic search)
NVIDIA_NIM_API_KEY=nvapi-your_nvidia_nim_api_key_here
NVIDIA_NIM_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
